{
  "private": true,
  "name": "@lumir/react-kit",
  "version": "0.0.0-private",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./components": {
      "types": "./build/components/index.d.ts",
      "default": "./build/components/index.js"
    },
    "./hooks": {
      "types": "./build/hooks/index.d.ts",
      "default": "./build/hooks/index.js"
    },
    "./svgs": {
      "types": "./build/svgs/index.d.ts",
      "default": "./build/svgs/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "./components": [
        "./build/components/index.d.ts"
      ],
      "./hooks": [
        "./build/hooks/index.d.ts"
      ],
      "./svgs": [
        "./build/svgs/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsgo -b tsconfig.build.json",
    "dev": "tsgo -b tsconfig.build.json --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/browser-playwright": "^4.1.6",
    "playwright": "^1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "vitest": "^4.1.6",
    "vitest-browser-react": "^2.2.0"
  }
}
