{
  "private": true,
  "name": "lumir.page",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "engines": {
    "node": "^24.15.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^24.15.0",
      "onFail": "error"
    },
    "packageManager": {
      "name": "npm",
      "version": ">=11.12.1",
      "onFail": "error"
    }
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "playground"
  ],
  "scripts": {
    "prepare": "husky",
    "test": "node --run test:types && node --run test:unit",
    "test:types": "npm run test:types -w apps/blog && tsgo -b",
    "test:unit": "vitest run --coverage",
    "test:a:a": "npm run test -w apps/api",
    "test:a:b": "npm run test -w apps/blog",
    "test:pkg:rk": "npm run test -w packages/react-kit",
    "test:pkg:rhp": "npm run test -w packages/rehype-plugins",
    "test:pkg:rmp": "npm run test -w packages/remark-plugins",
    "test:pkg:u": "npm run test -w packages/utils",
    "pack:pkg": "npm pack --workspace packages --dry-run",
    "pack:pkg:rk": "npm pack -w packages/react-kit --dry-run",
    "pack:pkg:rhp": "npm pack -w packages/rehype-plugins --dry-run",
    "pack:pkg:rmp": "npm pack -w packages/remark-plugins --dry-run",
    "pack:pkg:s": "npm pack -w packages/styles --dry-run",
    "pack:pkg:t": "npm pack -w packages/types --dry-run",
    "pack:pkg:u": "npm pack -w packages/utils --dry-run",
    "dev:a": "npm run dev -w apps/api",
    "dev:b": "npm-run-all -c -l -p dev:a:a dev:a:b dev:pkg",
    "dev:m": "npm-run-all -c -l -p dev:a:a dev:a:m dev:pkg",
    "dev:a:a": "npm run dev -w apps/api",
    "dev:a:b": "npm run dev -w apps/blog",
    "dev:a:m": "npm run dev -w apps/moing",
    "dev:pkg": "tsgo -b tsconfig.build.json --watch",
    "dev:pkg:rk": "npm run dev -w packages/react-kit",
    "dev:pkg:rhp": "npm run dev -w packages/rehype-plugins",
    "dev:pkg:rmp": "npm run dev -w packages/remark-plugins",
    "dev:pkg:u": "npm run dev -w packages/utils",
    "dev:pg": "npm run dev -w playground",
    "build": "node --run build:a && node --run build:pkg",
    "build:a": "npm run build -w apps/api",
    "build:b": "npm run build -w apps/blog",
    "build:m": "npm run build -w apps/moing",
    "build:a:a": "npm run build -w apps/api",
    "build:a:b": "npm run build -w apps/blog",
    "build:a:m": "npm run build -w apps/moing",
    "build:pkg": "tsgo -b tsconfig.build.json",
    "build:pkg:rk": "npm run build -w packages/react-kit",
    "build:pkg:rhp": "npm run build -w packages/rehype-plugins",
    "build:pkg:rmp": "npm run build -w packages/remark-plugins",
    "build:pkg:t": "npm run build -w packages/types",
    "build:pkg:u": "npm run build -w packages/utils",
    "start:b": "npm run start -w apps/blog",
    "start:m": "npm run start -w apps/moing",
    "start:a:b": "npm run start -w apps/blog",
    "start:a:m": "npm run start -w apps/moing",
    "analyze": "npm run analyze -w apps/blog",
    "req": "node ./apps/api/src/dev/client.ts",
    "fix": "npm-run-all -c -l -p fix:*",
    "fix:eslint": "eslint --fix --cache --cache-strategy content",
    "fix:stylelint": "stylelint --fix **/*.css",
    "fix:prettier": "prettier . --write --ignore-unknown",
    "fix:markdownlint": "markdownlint **/*.md --fix",
    "fix:clangformat": "node scripts/clang-format.ts --fix",
    "lint": "npm-run-all -c -l -p lint:*",
    "lint:eslint": "eslint --cache --cache-strategy content",
    "lint:stylelint": "stylelint **/*.css",
    "lint:prettier": "prettier . --check --ignore-unknown",
    "lint:editorconfig": "editorconfig-checker -config .editorconfig-checker.json",
    "lint:markdownlint": "markdownlint **/*.md",
    "lint:clangformat": "node scripts/clang-format.ts"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@typescript/native-preview": "^7.0.0-dev.20260624.1",
    "@vitest/coverage-v8": "^4.1.8",
    "clang-format-node": "^3.0.7",
    "editorconfig-checker": "^6.1.1",
    "eslint": "^9.39.4",
    "eslint-config-bananass": "^0.7.0",
    "eslint-markdown": "^0.11.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "markdownlint-cli": "^0.49.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
