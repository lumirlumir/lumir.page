{
  "private": true,
  "name": "blog",
  "type": "module",
  "engines": {
    "node": "^24.15.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node --run test:types && next build",
    "start": "vite preview --open --outDir build --port 3001",
