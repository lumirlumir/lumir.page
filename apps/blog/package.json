    "@lumir/remark-plugins": "*",
    "@lumir/styles": "*",
    "@lumir/utils": "*",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "client-only": "^0.0.1",
    "katex": "^0.17.0",
    "mdast-util-to-string": "^4.0.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rehype-autolink-headings": "^7.1.0",
